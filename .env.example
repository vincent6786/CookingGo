# Copy to .env.local for local dev. Set the same two vars in Vercel
# (Settings → Environment Variables, all three environments) for deploy.
#
# Get these from your Supabase project: Settings → API.
# The anon key is safe to ship to the browser — it's gated by Row-Level
# Security. NEVER paste the service_role key here or anywhere client-side.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY
